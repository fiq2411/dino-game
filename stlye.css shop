body {
  font-family: Arial;
  text-align: center;
  background: #f5f5f5;
}

.product {
  background: white;
  padding: 15px;
  margin: 10px auto;
  width: 200px;
  border-radius: 10px;
  box-shadow: 0 0 10px #ccc;
}

button {
  padding: 8px 12px;
  background: green;
  color: white;
  border: none;
  border-radius: 5px;
}
